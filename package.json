{
  "name": "inkwell-backend",
  "version": "1.0.0",
  "description": "Inkwell blog platform \u2026 Supabase + Express backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/utils/seeder.js",
    "kill-port": "npx kill-port 4000",
    "fresh": "npx kill-port 4000 && node src/index.js",
    "fresh:dev": "npx kill-port 4000 && nodemon src/index.js"
  },
  "nodemonConfig": {
    "ignore": [
      "supabase/**",
      "*.md"
    ],
    "delay": 500
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "joi": "^17.12.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}